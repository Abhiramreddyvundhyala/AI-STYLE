# Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Replicate API (for AI transformations via flux-kontext-pro)
# ⚠️ Do NOT add VITE_ prefix — this must stay server-side only (proxied via Vite dev server)
REPLICATE_API_TOKEN=your-replicate-token

# Razorpay (for payments)
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Cloudflare Worker Proxy (optional - for Jio ISP blocking)
VITE_SUPABASE_PROXY_URL=https://your-worker.workers.dev

# Gemini API (for AI image generation)
GEMINI_API_KEY=your-gemini-api-key
VITE_GEMINI_API_KEY=your-gemini-api-key

# GPT Image 2.0 API (Primary AI Model)
VITE_GPT_IMAGE_API_KEY=your-gpt-image-api-key
GPT_IMAGE_API_KEY=your-gpt-image-api-key
